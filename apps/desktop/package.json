{
  "name": "media-parser-desktop",
  "version": "0.2.6",
  "private": true,
  "description": "Local-first desktop media parsing software.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/run-electron-vite.mjs dev",
    "build": "node scripts/run-electron-vite.mjs build",
    "prepare:release-tools": "node scripts/prepare-release-tools.mjs",
    "build:media-core": "node scripts/build-media-core.mjs",
    "dist": "npm run dist:mac",
    "dist:mac": "node scripts/dist-mac.mjs",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "preview": "node scripts/run-electron-vite.mjs preview"
  },
  "build": {
    "appId": "space.jacory.media-parser",
    "productName": "Media Parser",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/resources/media-core",
        "to": "media-core"
      },
      {
        "from": "build/resources/bin",
        "to": "bin"
      }
    ],
    "asarUnpack": [
      "build/resources/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "JacoryCYJin",
        "repo": "media-parser"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "lucide-vue-next": "^0.468.0",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@swc/core": "^1.7.0",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.18",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "ffmpeg-static": "^5.3.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.0",
    "vite": "^5.1.4",
    "vue-tsc": "^2.0.0"
  }
}
